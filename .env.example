# Copia questo file in .env.local e compila con i tuoi valori

# ─── Supabase (frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Admin email ──────────────────────────────────────────────────────────────
VITE_ADMIN_EMAIL=tua@email.com

# ─── Sentry (opzionale, ma raccomandato in produzione) ────────────────────────
# Il DSN è pubblico per design — l'allowList del dominio si configura nel pannello Sentry.
VITE_SENTRY_DSN=https://KEY@oXXX.ingest.sentry.io/PROJECT_ID

# ─── Variabili SOLO per Vercel (NON mettere in .env.local — vanno nel pannello Vercel) ──
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...  ← service_role key, NON la anon key
# RESEND_API_KEY=re_...
