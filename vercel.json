{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/ai.js": { "maxDuration": 30 },
    "api/admin.js": { "maxDuration": 15 },
    "api/send-email.js": { "maxDuration": 10 },
    "api/referral.js":         { "maxDuration": 10 },
    "api/sync-delivery.js":    { "maxDuration": 30 },
    "api/cron-report-mensile.js": { "maxDuration": 60 },
    "api/cron-notifiche.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/sync-delivery", "schedule": "0 2 * * *" },
    { "path": "/api/cron-report-mensile", "schedule": "0 7 1 * *" },
    { "path": "/api/cron-notifiche", "schedule": "0 8 * * *" }
  ]
}
