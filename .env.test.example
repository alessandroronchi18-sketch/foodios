# Credenziali account di test dedicato per Playwright
# NON committare il file .env.test reale — solo questo .example.
# In locale: cp .env.test.example .env.test && export $(cat .env.test | xargs)
# In CI: configura come GitHub Secrets (vedi .github/workflows/playwright.yml).

TEST_EMAIL=playwright@foodios.test
TEST_PASSWORD=changeme

# Opzionale: dominio per le email generate dal test di signup.
TEST_SIGNUP_DOMAIN=foodios-e2e.test

# Opzionale: override base URL (default: https://foodios-rose.vercel.app).
# BASE_URL=http://localhost:5173
